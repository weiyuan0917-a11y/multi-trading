# Web 设置页密钥实际写入 data/user_env/<登录名>.env；根目录 .env 仅作占位/兼容。
# 首次升级时若仅有根 .env，会自动迁移到用户 davies 的 data/user_env 文件。
# 复制本文件为参考；勿将含真实密钥的文件提交到 Git。
# 券商提供方（第一阶段仅支持 longbridge，兼容 longport 别名）
BROKER_PROVIDER=longbridge
# 默认账户ID（AccountRegistry 会将无 account_id 请求路由到该账户）
DEFAULT_ACCOUNT_ID=default

# LongPort（必填，若不用文件内其它方式配置）
LONGPORT_APP_KEY=
LONGPORT_APP_SECRET=
LONGPORT_ACCESS_TOKEN=

# 飞书（可选；也可写在 mcp_server/notification_config.json，环境变量优先）
FEISHU_APP_ID=
FEISHU_APP_SECRET=
FEISHU_SCHEDULED_CHAT_ID=

FEISHU_BOT_USE_API_PROXY=true
FEISHU_BOT_API_BASE_URL=http://127.0.0.1:8010
FEISHU_BOT_API_TIMEOUT_SECONDS=8

#opnbb
OPENBB_BASE_URL=http://127.0.0.1:6900
OPENBB_ENABLED=true
OPENBB_TIMEOUT_SECONDS=8

#行情API
TIINGO_API_KEY=
COINGECKO_API_KEY=
FINNHUB_API_KEY=
POLYGON_API_KEY=
TWELVE_DATA_API_KEY=
FRED_API_KEY=

# Public market data fallback (no broker account required; delayed/best-effort).
CN_MARKET_DATA_PROVIDER_ORDER=tencent_index,mootdx,local_cache,akshare,tushare,baostock
CN_MARKET_TENCENT_INDEX_ENABLED=true
CN_MARKET_MOOTDX_ENABLED=true
CN_MARKET_TENCENT_ENABLED=true
CN_MARKET_AKSHARE_ENABLED=true
CN_MARKET_TUSHARE_ENABLED=true
CN_MARKET_BAOSTOCK_ENABLED=true
PUBLIC_MARKET_DATA_PROVIDER_ORDER=polygon,twelvedata,tencent_hk,tencent_index,mootdx,eastmoney,akshare,cn_local_cache,yahoo,stooq,hk_local_cache,us_local_cache
PUBLIC_MARKET_POLYGON_ENABLED=true
PUBLIC_MARKET_TWELVEDATA_ENABLED=true
PUBLIC_MARKET_TENCENT_HK_ENABLED=true
PUBLIC_MARKET_TENCENT_INDEX_ENABLED=true
PUBLIC_MARKET_MOOTDX_ENABLED=true
PUBLIC_MARKET_EASTMONEY_ENABLED=true
PUBLIC_MARKET_YAHOO_ENABLED=true
PUBLIC_MARKET_AKSHARE_ENABLED=true
PUBLIC_MARKET_STOOQ_ENABLED=true
PUBLIC_MARKET_CN_LOCAL_CACHE_ENABLED=true
PUBLIC_MARKET_HK_LOCAL_CACHE_ENABLED=true
PUBLIC_MARKET_US_LOCAL_CACHE_ENABLED=true
PUBLIC_MARKET_DATA_TIMEOUT_SECONDS=2.5
# Set to true when you want dashboard/market snapshots to skip Longbridge even if credentials exist.
PUBLIC_MARKET_DATA_ONLY=false
TRADINGAGENTS_DATA_SOURCE=auto
TRADINGAGENTS_PUBLIC_MARKET_SOURCE=auto


# ========== 性能与稳定性优化 ==========
# 以下键在 data/user_env/<登录名>.env 中若缺失，会在首次登录/打开设置时自动补全为下列默认值。

# Watchdog 健康检查优化（防止频繁重启）
LONGPORT_WATCHDOG_HEALTH_TIMEOUT=15
LONGPORT_WATCHDOG_CONFIRM_TIMEOUT=45
LONGPORT_WATCHDOG_FAILS_BEFORE_RESTART=40
LONGPORT_WATCHDOG_RESTART_COOLDOWN=300
LONGPORT_WATCHDOG_STARTUP_GRACE=120

# LongPort 连接管理
LONGPORT_CONNECTION_LIMIT=15
LONGPORT_HISTORY_MAX_CONCURRENCY=3

# Worker 通过 API 代理访问（降低连接占用）
AUTO_TRADER_WORKER_USE_API_PROXY=true
AUTO_TRADER_API_BASE_URL=http://127.0.0.1:8010
AUTO_TRADER_API_PROXY_TIMEOUT_SECONDS=15
# 代理模式下 /trade/* 需用户鉴权：推荐 Setup「个人 API Key」生成后填入（请求头 X-Api-Key）
# AUTO_TRADER_API_KEY=mt_live_...
# 兼容：浏览器登录 session token（Authorization Bearer）
# AUTO_TRADER_API_BEARER_TOKEN=
CORS_ALLOW_ORIGINS=http://127.0.0.1:3000,http://localhost:3000



# K线缓存（减少重复请求）
LONGPORT_USE_SERVER_KLINE_CACHE=1

# 直接连接回退（仅在 API 代理失败时启用）
LONGPORT_DIRECT_FALLBACK=0


# ========== MultiTrading Cloud Console / Local Agent split ==========
# Local trading/research secrets belong on the user's machine. Do not put
# broker credentials, OpenBB credentials, worker keys, or user data in Vercel.
#
# Web console split:
# - Cloud console: auth, subscription, billing, entitlements.
# - Local Agent: setup, research, trade, broker, market data, backtest.
#
# For Next.js/Vercel frontend variables, also see frontend/.env.local.example.
NEXT_PUBLIC_LOCAL_AGENT_API_BASE=http://127.0.0.1:8010
NEXT_PUBLIC_API_BASE=http://127.0.0.1:8010
NEXT_PUBLIC_LOCAL_AGENT_OWNER_ID=
NEXT_PUBLIC_LOCAL_AGENT_OWNER_EMAIL=
NEXT_PUBLIC_LOCAL_AGENT_OWNER_PLAN=premium
NEXT_PUBLIC_LOCAL_AGENT_OWNER_ROLE=admin
NEXT_PUBLIC_LOCAL_AGENT_OWNER_IS_ADMIN=true
NEXT_PUBLIC_CLOUD_API_BASE=
NEXT_PUBLIC_CONSOLE_API_BASE=
NEXT_PUBLIC_CLOUD_API_ALLOW_LOCAL_FALLBACK=false
NEXT_PUBLIC_AUTH_MODE=hybrid
NEXT_PUBLIC_MT_PLAN=free

# Local Agent owner allow-list. Use this when a cloud user is intentionally
# mapped to an existing local owner such as davies.
LOCAL_AGENT_OWNER_ID=
LOCAL_AGENT_ALLOWED_OWNERS=
LOCAL_AGENT_ALLOW_USER_OWNERS=true

# Clerk / Convex placeholders for the cloud console path.
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
CLERK_WEBHOOK_SIGNING_SECRET=
NEXT_PUBLIC_CONVEX_URL=
NEXT_PUBLIC_CONVEX_HTTP_ACTIONS_URL=
CLERK_JWT_ISSUER_DOMAIN=
CONVEX_BOOTSTRAP_ADMIN_EMAIL=
CONVEX_BOOTSTRAP_LOCAL_OWNER_ID=

# Billing placeholders. Use only the provider you choose.
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
MT_BILLING_WEBHOOK_SECRET=
RESEND_API_KEY=
LICENSE_EMAIL_FROM=
LICENSE_EMAIL_REPLY_TO=
LICENSE_EMAIL_SUBJECT_PREFIX=MultiTrading
FEISHU_BILLING_WEBHOOK_URL=
FEISHU_BILLING_WEBHOOK_SECRET=
FEISHU_BILLING_APP_ID=
FEISHU_BILLING_APP_SECRET=
FEISHU_BILLING_CHAT_ID=
FEISHU_BILLING_ADMIN_OPEN_IDS=
FEISHU_BILLING_ADMIN_CHAT_IDS=
NEXT_PUBLIC_PAYMENT_QR_WECHAT_URL=
NEXT_PUBLIC_PAYMENT_QR_ALIPAY_URL=
NEXT_PUBLIC_PAYMENT_QR_WISE_URL=

# Optional signed local license cache. This lets the Local Agent enforce
# subscription entitlements without calling overseas auth services on startup.
LOCAL_LICENSE_SIGNING_SECRET=
CONVEX_LOCAL_LICENSE_SIGNING_SECRET=
CONVEX_LOCAL_LICENSE_TTL_DAYS=7
LOCAL_LICENSE_ALLOW_UNSIGNED=false
