# MultiTrading web console environment.
# Copy to frontend/.env.local for local frontend development.

# Local Agent API: setup, research, trade, broker, market data, backtest.
NEXT_PUBLIC_LOCAL_AGENT_API_BASE=http://127.0.0.1:8010

# user = normal customer/local-agent frontend; admin = private operator console.
# User release packages are generated with admin source physically removed.
NEXT_PUBLIC_MT_EDITION=user

# Optional cloud-to-local owner binding. Use when a Clerk account should read
# an existing Local Agent owner such as data/user_env/davies.env.
# If NEXT_PUBLIC_LOCAL_AGENT_OWNER_EMAIL is set, the owner header is only sent
# when the signed-in Clerk email matches it.
NEXT_PUBLIC_LOCAL_AGENT_OWNER_ID=
NEXT_PUBLIC_LOCAL_AGENT_OWNER_EMAIL=
NEXT_PUBLIC_LOCAL_AGENT_OWNER_PLAN=premium
NEXT_PUBLIC_LOCAL_AGENT_OWNER_ROLE=admin
NEXT_PUBLIC_LOCAL_AGENT_OWNER_IS_ADMIN=true

# Legacy alias. Keep during migration because a few old helper paths may still
# read NEXT_PUBLIC_API_BASE directly.
NEXT_PUBLIC_API_BASE=http://127.0.0.1:8010

# Cloud console API: auth, user profile, subscription, billing, entitlements.
# Leave empty or point to the local agent while Clerk/Convex is not wired yet.
# In Vercel, set this to your cloud control-plane API or Convex-backed endpoint.
NEXT_PUBLIC_CLOUD_API_BASE=
NEXT_PUBLIC_CONSOLE_API_BASE=

# Development only. When true, cloud-api falls back to local agent if a cloud
# base URL is configured but unavailable. Keep false in production.
NEXT_PUBLIC_CLOUD_API_ALLOW_LOCAL_FALLBACK=false

# Auth mode:
# - hybrid: local-first. Clerk/Convex are optional and never block startup.
# - local: local account only.
# - clerk: cloud-first Clerk login.
NEXT_PUBLIC_AUTH_MODE=hybrid

# Temporary local entitlement override before cloud billing is connected.
# Valid values: free, pro, premium.
NEXT_PUBLIC_MT_PLAN=free

# User edition billing should point customers to your cloud purchase page.
# Admin edition can use the local /api/billing/manual-orders proxy.
NEXT_PUBLIC_BILLING_PORTAL_URL=
NEXT_PUBLIC_BILLING_ORDER_API_URL=

# Clerk placeholders. Do not put secret values in NEXT_PUBLIC_* variables.
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
CLERK_WEBHOOK_SIGNING_SECRET=
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/auth
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/auth
NEXT_PUBLIC_CLERK_SIGN_IN_FALLBACK_REDIRECT_URL=/onboarding
NEXT_PUBLIC_CLERK_SIGN_UP_FALLBACK_REDIRECT_URL=/onboarding

# Convex placeholder.
NEXT_PUBLIC_CONVEX_URL=
NEXT_PUBLIC_CONVEX_HTTP_ACTIONS_URL=
CLERK_JWT_ISSUER_DOMAIN=
CONVEX_BOOTSTRAP_ADMIN_EMAIL=
CONVEX_BOOTSTRAP_LOCAL_OWNER_ID=

# Billing provider placeholders. Use the provider you choose; keep unused ones empty.
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
MT_BILLING_WEBHOOK_SECRET=
RESEND_API_KEY=
LICENSE_EMAIL_FROM=
LICENSE_EMAIL_REPLY_TO=
LICENSE_EMAIL_SUBJECT_PREFIX=MultiTrading

# Semi-manual payment QR codes. You can either set full image URLs here or
# place images at frontend/public/payments/wechat-qr.png and alipay-qr.png.
NEXT_PUBLIC_PAYMENT_QR_WECHAT_URL=
NEXT_PUBLIC_PAYMENT_QR_ALIPAY_URL=

# Optional signed local license cache for China-friendly local-first use.
# Convex / issuer should sign with RSA private key; Local Agent verifies with
# the matching public key. Keep unsigned import disabled unless you are testing
# on a trusted machine.
CONVEX_LOCAL_LICENSE_PRIVATE_KEY_PEM=
LOCAL_LICENSE_PRIVATE_KEY_PEM=
LOCAL_LICENSE_PUBLIC_KEY_PEM=
CONVEX_LOCAL_LICENSE_PUBLIC_KEY_PEM=
# Legacy HMAC compatibility for old License payloads only.
LOCAL_LICENSE_SIGNING_SECRET=
CONVEX_LOCAL_LICENSE_SIGNING_SECRET=
CONVEX_LOCAL_LICENSE_TTL_DAYS=7
LOCAL_LICENSE_ALLOW_UNSIGNED=false
